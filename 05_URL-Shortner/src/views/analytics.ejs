<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <%- include('./partials/styles') %>
  <title>Urly | Analytics</title>
</head>
<body>
  <%- include('./partials/navbar') %>

  <section class="analytics-hero">
    <div class="hero-glow" style="opacity:0.5;"></div>
    <div class="container">

      <!-- Header -->
      <div class="mb-5 fade-up">
        <div class="section-label">
          <% if (typeof shortId !== 'undefined' && shortId) { %>
            <i class="bi bi-link me-1"></i> /<%= shortId %>
          <% } else { %>
            <i class="bi bi-bar-chart me-1"></i> Overview
          <% } %>
        </div>
        <h1 class="section-title">Link Analytics</h1>
        <p class="section-sub">
          <% if (typeof shortId !== 'undefined' && shortId) { %>
            Detailed stats for your shortened link
          <% } else { %>
            Overview of all your shortened URLs
          <% } %>
        </p>
      </div>

      <!-- Stat Cards -->
      <div class="row g-4 mb-4 fade-up fade-up-1">
        <div class="col-6 col-md-3">
          <div class="analytics-card">
            <div class="label">Total Links</div>
            <div class="value"><%= typeof allUrls !== 'undefined' ? allUrls.length : 0 %></div>
            <div class="trend"><i class="bi bi-arrow-up-short"></i> All time</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="analytics-card">
            <div class="label">Total Clicks</div>
            <div class="value">
              <%= typeof allUrls !== 'undefined'
                ? allUrls.reduce((sum, u) => sum + (u.visitHistory ? u.visitHistory.length : 0), 0)
                : (typeof urlData !== 'undefined' && urlData ? urlData.visitHistory.length : 0) %>
            </div>
            <div class="trend"><i class="bi bi-cursor"></i> Cumulative</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="analytics-card">
            <div class="label">Most Clicked</div>
            <div class="value" style="font-size:1.4rem;">
              <% if (typeof allUrls !== 'undefined' && allUrls.length > 0) {
                const top = allUrls.reduce((a, b) =>
                  (a.visitHistory?.length || 0) > (b.visitHistory?.length || 0) ? a : b);
              %>/<%= top.shortId %>
              <% } else { %>—<% } %>
            </div>
            <div class="trend"><i class="bi bi-trophy"></i> Top performer</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="analytics-card">
            <div class="label">Avg Clicks</div>
            <div class="value">
              <% if (typeof allUrls !== 'undefined' && allUrls.length > 0) {
                const total = allUrls.reduce((sum, u) => sum + (u.visitHistory ? u.visitHistory.length : 0), 0);
                const avg = (total / allUrls.length).toFixed(1);
              %><%= avg %>
              <% } else { %>0<% } %>
            </div>
            <div class="trend"><i class="bi bi-graph-up"></i> Per link</div>
          </div>
        </div>
      </div>

      <!-- Link Details Table -->
      <% if (typeof shortId !== 'undefined' && shortId && typeof urlData !== 'undefined' && urlData) { %>
      <!-- Single URL analytics -->
      <div class="table-card mb-4 fade-up fade-up-2">
        <div class="p-3 border-bottom" style="border-color:var(--border)!important;">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
              <span style="font-size:0.75rem; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:var(--muted);">Original URL</span>
              <div style="font-size:0.88rem; color:var(--text); word-break:break-all; margin-top:0.2rem;">
                <i class="bi bi-link-45deg text-accent me-1" style="color:var(--accent)"></i>
                <%= urlData.redirectURL %>
              </div>
            </div>
            <a href="/<%= shortId %>" target="_blank"
              class="btn btn-sm" style="background:var(--accent); color:#fff; border:none; border-radius:8px; font-size:0.82rem; padding:0.4rem 1rem;">
              <i class="bi bi-box-arrow-up-right me-1"></i>Visit
            </a>
          </div>
        </div>

        <% if (urlData.visitHistory && urlData.visitHistory.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-borderless align-middle mb-0">
            <thead>
              <tr>
                <th>#</th>
                <th>Timestamp</th>
              </tr>
            </thead>
            <tbody>
              <% urlData.visitHistory.slice().reverse().forEach((visit, i) => { %>
              <tr>
                <td style="color:var(--muted); font-size:0.8rem;"><%= i + 1 %></td>
                <td>
                  <i class="bi bi-clock me-1" style="color:var(--accent);"></i>
                  <%= new Date(visit.timestamp).toLocaleString('en-US', {
                    month: 'short', day: 'numeric', year: 'numeric',
                    hour: '2-digit', minute: '2-digit'
                  }) %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div class="empty-state">
          <i class="bi bi-cursor"></i>
          <p class="mb-1" style="color:var(--text); font-weight:600;">No clicks yet</p>
          <p>Share your link to start tracking visits.</p>
        </div>
        <% } %>
      </div>

      <% } else { %>
      <!-- All URLs analytics -->
      <div class="table-card fade-up fade-up-2">
        <% if (typeof allUrls !== 'undefined' && allUrls.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-borderless align-middle mb-0">
            <thead>
              <tr>
                <th>#</th>
                <th>Short Link</th>
                <th>Original URL</th>
                <th>Clicks</th>
                <th>Last Click</th>
                <th>Details</th>
              </tr>
            </thead>
            <tbody>
              <% allUrls.forEach((url, i) => {
                const clicks = url.visitHistory ? url.visitHistory.length : 0;
                const lastClick = clicks > 0 ? url.visitHistory[url.visitHistory.length - 1].timestamp : null;
              %>
              <tr>
                <td style="color:var(--muted); font-size:0.8rem;"><%= i + 1 %></td>
                <td>
                  <a href="/<%= url.shortId %>" target="_blank" class="short-link">
                    <i class="bi bi-box-arrow-up-right me-1" style="font-size:0.75rem;"></i><%= url.shortId %>
                  </a>
                </td>
                <td>
                  <span class="original-url" title="<%= url.redirectURL %>"><%= url.redirectURL %></span>
                </td>
                <td>
                  <span class="clicks-badge"><i class="bi bi-cursor me-1"></i><%= clicks %></span>
                </td>
                <td style="color:var(--muted); font-size:0.82rem;">
                  <%= lastClick
                    ? new Date(lastClick).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'})
                    : '—' %>
                </td>
                <td>
                  <a href="/analytics/<%= url.shortId %>"
                    class="action-btn" style="text-decoration:none; display:inline-block;">
                    <i class="bi bi-bar-chart"></i>
                  </a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div class="empty-state">
          <i class="bi bi-bar-chart"></i>
          <p class="mb-1" style="color:var(--text); font-weight:600;">No data yet</p>
          <p>Shorten your first URL to see analytics here.</p>
        </div>
        <% } %>
      </div>
      <% } %>

    </div>
  </section>

  <%- include('./partials/footer') %>
  <%- include('./partials/scripts') %>
</body>
</html>
