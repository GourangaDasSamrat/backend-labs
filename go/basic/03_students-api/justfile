# Requires: go 1.22+, just

binary := "app"
main   := "./cmd/students-api"
config := "config/local.yaml"

# List all recipes
default:
    @just --list

# Run directly without producing a binary
run:
    go run {{main}} -config {{config}}

# Run directly with live reload
dev:
    air {{main}} -- -config {{config}}

# Compile the binary
build:
    go build -o {{binary}} {{main}}

# Build then run
start: build
    ./{{binary}} -config {{config}}

# Format all Go source
fmt:
    gofmt -w .

# Lint all packages
lint:
    golangci-lint run

# Run all tests
test:
    go test -v ./...

# Generate test stubs for all Go files
test-gen:
    gotests -w -all ./...

# Generate test stubs for a specific file
test-gen-file file:
    gotests -w -all {{file}}

# Remove compiled binary, dist/, and tmp/
clean:
    go clean
    go clean --testcache
    rm -f {{binary}}
    rm -rf dist/
    rm -rf tmp/

# Cross-compile for common targets (output → ./dist/)
build-all:
    mkdir -p dist && \
    GOOS=linux   GOARCH=amd64  go build -o dist/{{binary}}-linux-amd64       {{main}} && \
    GOOS=linux   GOARCH=arm64  go build -o dist/{{binary}}-linux-arm64       {{main}} && \
    GOOS=darwin  GOARCH=arm64  go build -o dist/{{binary}}-darwin-arm64      {{main}} && \
    GOOS=darwin  GOARCH=amd64  go build -o dist/{{binary}}-darwin-amd64      {{main}} && \
    GOOS=windows GOARCH=amd64  go build -o dist/{{binary}}-windows-amd64.exe {{main}}
