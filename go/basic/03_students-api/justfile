# Requires: go 1.22+, just

binary := "app"
main   := "./cmd/students-api"
config := "config/local.yaml"

# Production Flags
export CGO_ENABLED := "0"
ld_flags           := "-s -w"
build_tags         := "-trimpath"

# List all recipes
default:
    @just --list

# --- Development ---

# Run directly
run:
    go run {{main}} -config {{config}}

# Run with live reload
dev:
    air {{main}} -- -config {{config}}

# --- Quality & Security ---

# Format source code
fmt:
    go mod tidy
    gofmt -w .

# Lint all packages
lint:
    golangci-lint run

# Scan for vulnerabilities
vuln:
    govulncheck ./...

# Run all tests
test:
    go test -v ./...

# --- Testing Stubs ---

# Generate all test stubs
test-gen:
    gotests -w -all ./...

# Generate test for specific file
test-gen-file file:
    gotests -w -all {{file}}

# --- Build ---

# Quick local build
build:
    go build -o {{binary}} {{main}}

# Secure production build
build-prod:
    go build {{build_tags}} -ldflags="{{ld_flags}}" -o {{binary}} {{main}}

# Build for all platforms
build-all:
    mkdir -p dist
    @for os in linux darwin windows; do \
        for arch in amd64 arm64; do \
            ext=""; [ "$os" = "windows" ] && ext=".exe"; \
            echo "Building for $os/$arch..."; \
            GOOS=$os GOARCH=$arch go build {{build_tags}} -ldflags="{{ld_flags}}" -o dist/{{binary}}-$os-$arch$ext {{main}}; \
        done; \
    done

# Clean artifacts and cache
clean:
    go clean
    go clean --testcache
    rm -f {{binary}}
    rm -rf dist/
    rm -rf tmp/

