{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "paths": {
      "@db": ["./generated/prisma/client"],
      "@db/models": ["./generated/prisma/models"]
    }
  },
  "include": ["src/**/*"]
}
