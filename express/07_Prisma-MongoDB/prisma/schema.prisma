generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  email    String  @unique
  name     String?
  password String
  posts    Post[]
}

model Post {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  slug     String
  title    String
  content  String?
  author   User    @relation(fields: [authorId], references: [id])
  authorId String  @db.ObjectId
}
