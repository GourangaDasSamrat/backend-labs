{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "paths": {
      "@db": ["./src/lib/prisma"],
      "@db/client": ["./generated/prisma/client"],
      "@db/models": ["./generated/prisma/models"],
      "@/types/*": ["./src/types/*"]
    }
  },
  "include": ["src/**/*"]
}
